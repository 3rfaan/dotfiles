{
  "editor.inlayHints.enabled": "on",

  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Iosevka Nerd Font', 'CaskaydiaCove Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 15,
  "editor.fontWeight": 700,

  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
  },

  "editor.mouseWheelZoom": true,
  "editor.wordWrap": "on",
  "editor.autoIndentOnPaste": true,
  "editor.cursorBlinking": "expand",
  "editor.fontLigatures": true,
  "editor.lineNumbers": "relative",

  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": 700,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.initialHint": false,

  "window.autoDetectColorScheme": true,
  "workbench.colorTheme": "Duskfox",
  "workbench.preferredLightColorTheme": "Dayfox",
  "workbench.preferredDarkColorTheme": "Duskfox",
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "file-icons",

  "vim.useSystemClipboard": true,
  "svelte.enable-ts-plugin": true,
}
